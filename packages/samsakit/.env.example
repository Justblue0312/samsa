# Database (read-only access to Samsa DB)
DATABASE_URL=postgresql://samsa_readonly:samsa@localhost:5432/samsa

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Connect-RPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# WebSocket
WS_HOST=0.0.0.0
WS_PORT=8083

# Go Server (for callbacks)
GO_SERVER_URL=http://localhost:8000

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=100

# Agent Limits
MAX_TOKENS_QUERY_GENERATOR=4000
MAX_REQUESTS_QUERY_GENERATOR=3
MAX_TOKENS_QUERY_VALIDATOR=3000
MAX_REQUESTS_QUERY_VALIDATOR=2
MAX_TOKENS_RECOMMENDATION=8000
MAX_TOOL_CALLS_RECOMMENDATION=5

# Freshness decay windows (hours)
DECAY_WINDOW_BOOKMARKS=48
DECAY_WINDOW_FAVORITES=72
DECAY_WINDOW_RECENTLY_VIEWED=24
DECAY_WINDOW_SAME_GENRE=72
